# ========================================
# STS Project - Environment Variables
# ========================================
# Copy this file to .env and fill in the values

# ========================================
# Application
# ========================================
APP_NAME=STS
APP_ENV=development
DEBUG=true

# ========================================
# Frontend
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========================================
# Backend
# ========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ========================================
# Database (PostgreSQL)
# ========================================
DATABASE_URL=postgresql+asyncpg://sts:sts_password@localhost:5432/sts
POSTGRES_USER=sts
POSTGRES_PASSWORD=sts_password
POSTGRES_DB=sts
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ========================================
# Authentication
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# OpenAI API
# ========================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ========================================
# Optional: Redis (Phase 3)
# ========================================
# REDIS_URL=redis://localhost:6379/0

# ========================================
# Optional: RabbitMQ (Phase 3)
# ========================================
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ========================================
# Optional: Elasticsearch (Phase 3)
# ========================================
# ELASTICSEARCH_URL=http://localhost:9200

# ========================================
# GCP (Production)
# ========================================
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=asia-east1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
