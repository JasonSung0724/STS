# ========================================
# STS Project - Environment Variables
# ========================================
# Copy this file to .env and fill in the values

# ========================================
# Application
# ========================================
APP_NAME=STS
APP_ENV=development
DEBUG=true

# ========================================
# Frontend
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========================================
# Backend
# ========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# ========================================
# Database (PostgreSQL)
# ========================================
DATABASE_URL=postgresql+asyncpg://sts:sts_password@localhost:5432/sts
POSTGRES_USER=sts
POSTGRES_PASSWORD=sts_password
POSTGRES_DB=sts
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ========================================
# Redis Cache
# ========================================
REDIS_URL=redis://localhost:6379/0

# ========================================
# Authentication
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# Supabase (for Google OAuth)
# ========================================
USE_SUPABASE=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ========================================
# LINE OAuth (for LINE Login)
# ========================================
# Get from LINE Developers Console: https://developers.line.biz/
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_REDIRECT_URI=http://localhost:3000/auth/callback

# ========================================
# OpenAI API (Required for AI features)
# ========================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ========================================
# Optional: Alternative AI Providers
# ========================================
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# GOOGLE_API_KEY=your-google-api-key

# ========================================
# Production Settings (uncomment for production)
# ========================================
# APP_ENV=production
# DEBUG=false
# JWT_SECRET=generate-a-secure-random-string-here
